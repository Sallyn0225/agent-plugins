{
  "name": "@sallyn0225/image-gen",
  "version": "2.0.0",
  "description": "Multi-provider image generation and editing: MCP server + CLI for gpt-image-2, grok-imagine-image, gemini-3.1-flash-image",
  "type": "module",
  "bin": {
    "image-gen": "dist/cli.js",
    "image-gen-mcp": "dist/mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "skills",
    "config.example.json",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/mcp.js",
    "cli": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "smoke": "node scripts/smoke.mjs",
    "smoke:offline": "vitest run --root ../.. tests/image-gen/offline-smoke.test.ts",
    "smoke:live": "node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "image-generation",
    "image-edit",
    "gpt-image-2",
    "grok-imagine-image",
    "gemini",
    "text-to-image",
    "agent-plugins",
    "agent-skills"
  ],
  "author": "Sallyn0225",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentPlugin": {
    "schemaVersion": 1,
    "id": "image-gen",
    "displayName": "Image Generation",
    "maturity": "stable",
    "interfaces": {
      "library": true,
      "cli": true,
      "mcp": true,
      "skill": true
    },
    "mcp": {
      "transport": "stdio",
      "tools": [
        "list_image_models",
        "generate_image",
        "edit_image"
      ]
    },
    "skill": {
      "format": "agent-skills",
      "path": "skills/image-gen"
    },
    "verification": {
      "automated": [
        "unit",
        "offline-cli",
        "offline-mcp",
        "docs",
        "metadata",
        "package-contents"
      ],
      "liveProviders": "manual"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sallyn0225/agent-plugins.git",
    "directory": "packages/image-gen"
  },
  "homepage": "https://github.com/Sallyn0225/agent-plugins/tree/main/packages/image-gen#readme",
  "bugs": {
    "url": "https://github.com/Sallyn0225/agent-plugins/issues"
  }
}
