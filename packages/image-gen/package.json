{
  "name": "@sallyn0225/image-gen",
  "version": "1.1.0",
  "description": "Multi-provider image generation and editing: MCP server + CLI for gpt-image-2, grok-imagine-image, gemini-3.1-flash-image",
  "type": "module",
  "bin": {
    "image-gen": "./dist/cli.js",
    "image-gen-mcp": "./dist/mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "config.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/mcp.js",
    "cli": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "image-generation",
    "image-edit",
    "gpt-image-2",
    "grok-imagine-image",
    "gemini",
    "text-to-image"
  ],
  "author": "sallyn0225",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sallyn0225/pi-packages.git",
    "directory": "packages/image-gen"
  },
  "homepage": "https://github.com/Sallyn0225/pi-packages/tree/main/packages/image-gen#readme",
  "bugs": {
    "url": "https://github.com/Sallyn0225/pi-packages/issues"
  }
}
