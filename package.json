{
  "name": "agent-plugins",
  "private": true,
  "version": "0.1.0",
  "description": "Host-independent Capability Plugins for coding agents: CLI, MCP, and Agent Skills",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:image-gen": "npm run build -w @sallyn0225/image-gen",
    "image-gen": "npm run cli -w @sallyn0225/image-gen --",
    "image-gen:mcp": "npm run start -w @sallyn0225/image-gen",
    "typecheck": "tsc -p tsconfig.json && npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "validate:plugins": "tsx scripts/agent-plugin/validate.ts",
    "catalog:generate": "tsx scripts/agent-plugin/generate-catalog.ts",
    "catalog:check": "tsx scripts/agent-plugin/generate-catalog.ts --check",
    "publish:image-gen": "npm publish -w @sallyn0225/image-gen"
  },
  "keywords": [
    "mcp",
    "skills",
    "coding-agent",
    "cli",
    "image-generation",
    "agent-plugins"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sallyn0225/agent-plugins.git"
  },
  "homepage": "https://github.com/Sallyn0225/agent-plugins#readme",
  "bugs": {
    "url": "https://github.com/Sallyn0225/agent-plugins/issues"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7",
    "zod": "^3.25.76"
  }
}
